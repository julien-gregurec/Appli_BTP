NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
DISABLE_EMAIL_LOGIN=false
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=https://votre-domaine.fr
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Abonnement SaaS Liria -> entreprises clientes (Stripe Billing plateforme).
# Ce secret de webhook est distinct de STRIPE_WEBHOOK_SECRET utilisé par Connect.
STRIPE_WEBHOOK_ABONNEMENT_SECRET=
STRIPE_PRICE_ESSENTIEL_MENSUEL=
STRIPE_PRICE_ESSENTIEL_ANNUEL=
STRIPE_PRICE_PRO_MENSUEL=
STRIPE_PRICE_PRO_ANNUEL=
STRIPE_PRICE_PREMIUM_MENSUEL=
STRIPE_PRICE_PREMIUM_ANNUEL=
# Phase variable : prix récurrents des comptes au-delà du quota de l’offre.
STRIPE_PRICE_COMPTE_SUP_ESSENTIEL_MENSUEL=
STRIPE_PRICE_COMPTE_SUP_ESSENTIEL_ANNUEL=
STRIPE_PRICE_COMPTE_SUP_PRO_MENSUEL=
STRIPE_PRICE_COMPTE_SUP_PRO_ANNUEL=
STRIPE_PRICE_COMPTE_SUP_PREMIUM_MENSUEL=
STRIPE_PRICE_COMPTE_SUP_PREMIUM_ANNUEL=
STRIPE_AUTOMATIC_TAX_ENABLED=false
# Vercel l’envoie en Bearer à la tâche nocturne /api/cron/abonnements.
CRON_SECRET=

# Coffre bancaire : clé AES-256 générée avec `openssl rand -base64 32`.
# Ne jamais la changer sans procédure de rotation/rechiffrement des IBAN existants.
BANK_DATA_ENCRYPTION_KEY=

# Powens Pay (contrat plateforme requis). Utiliser les URL du domaine remis par Powens.
POWENS_API_BASE_URL=https://votre-domaine.biapi.pro/2.0
POWENS_WEBVIEW_BASE_URL=https://votre-domaine.biapi.pro/2.0/auth/webview/payment
POWENS_CLIENT_ID=
POWENS_CLIENT_SECRET=

# Secret d’au moins 32 caractères pour le dépôt serveur-à-serveur des bulletins
# par l’intégration de l’expert-comptable. Ne jamais le transmettre par email.
PAYROLL_IMPORT_SECRET=
